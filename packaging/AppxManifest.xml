<?xml version="1.0" encoding="utf-8"?>
<!--
  MSIX-manifest voor de Microsoft Store-build van Lazytype.
  De tokens worden bij het bouwen vervangen (zie .github/workflows/windows-build.yml):
    __VERSION__          -> 4-delige versie uit site/version.json (bijv. 1.8.15.0)
    __IDENTITY_NAME__    -> Package/Identity/Name uit Partner Center (repo-var MSIX_IDENTITY_NAME)
    __PUBLISHER__        -> Publisher (CN=...) uit Partner Center (repo-var MSIX_PUBLISHER)
    __PUBLISHER_DISPLAY__-> Publisher display name (repo-var MSIX_PUBLISHER_DISPLAY)
  Zonder repo-vars worden veilige placeholders gebruikt (pakket bouwt + lokaal te testen
  met een self-signed cert; voor de echte Store-upload de juiste waarden invullen).
-->
<Package xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
         xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
         xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
         IgnorableNamespaces="uap rescap">

  <Identity Name="__IDENTITY_NAME__"
            Publisher="__PUBLISHER__"
            Version="__VERSION__"
            ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Lazytype</DisplayName>
    <PublisherDisplayName>__PUBLISHER_DISPLAY__</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22631.0" />
  </Dependencies>

  <Resources>
    <Resource Language="nl-NL" />
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application Id="Lazytype" Executable="Lazytype.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Lazytype"
        Description="Dicteer in elke app — spreek en het verschijnt als tekst."
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png"
                         Square71x71Logo="Assets\Square71x71Logo.png"
                         Square310x310Logo="Assets\Square310x310Logo.png" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <Capability Name="internetClient" />
    <DeviceCapability Name="microphone" />
  </Capabilities>
</Package>
