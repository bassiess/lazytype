# Kopieer dit bestand naar .env en vul in wat je wilt gebruiken.

# Optioneel: OpenAI API-key voor de cloud-engine (whisper-1).
# Zonder key werkt alleen de lokale engine (whisper.cpp).
OPENAI_API_KEY=

# Optioneel: welk lokaal model standaard gebruikt wordt voor uploads (bestandsnaam uit models/).
# Standaard pakt de server het grootste .bin-bestand dat er ligt; in de UI is het per upload te kiezen.
# WHISPER_MODEL=ggml-large-v3-turbo-q5_0.bin

# Optioneel: welk model de live-modus gebruikt. Live moet snel zijn: standaard small (of base).
# Zet op ggml-base.bin als live te traag aanvoelt op jouw machine.
# WHISPER_MODEL_LIVE=ggml-small.bin

# Optioneel: poort van de webserver (standaard 3000).
# PORT=3000

# ── Dicteertool (dictate.py / dictate_tray.py) ──────────────────────────
# Groq API-key (gratis via console.groq.com/keys) — vereist voor de Groq-engine
# én voor de AI-nabewerking (opschonen/vertalen).
GROQ_API_KEY=

# Welke engine standaard: groq | openai | local
# DICTATE_ENGINE=groq

# Spreektaal (transcriptie-hint): nl | en | de | fr | ... | auto
# DICTATE_LANGUAGE=nl

# Tweede sneltoets voor command mode (selecteer tekst → houd in → spreek instructie,
# bv. "maak formeler" / "vat samen" / "vertaal naar Engels"). Standaard rechter Ctrl.
# DICTATE_COMMAND_HOTKEY=ctrl_r

# Derde sneltoets: dicteren + meteen vertalen naar DICTATE_TRANSLATE_TARGET.
# Bv. houd 'm in en spreek Nederlands → Engelse tekst. Standaard rechter Shift.
# (Allemaal ook instelbaar via Instellingen / de onboarding-wizard.)
# DICTATE_TRANSLATE_HOTKEY=shift_r
# DICTATE_TRANSLATE_TARGET=en

# Onboarding-wizard is afgerond? (wordt automatisch op 1 gezet na de eerste keer)
# DICTATE_ONBOARDED=

# Eigen woordenboek staat in dictionary.txt (namen/jargon, één per regel).

# Dicteer-geschiedenis lokaal bewaren (laatste 25, terug te kopiëren via het menu).
# DICTATE_HISTORY=1

# Klein drijvend overlay-balkje (live waveform + status + snel taal/AI aanpassen).
# DICTATE_OVERLAY=1

# AI-nabewerking na transcriptie:
#   off    = uit (ruwe transcriptie)
#   clean  = opschonen (stopwoorden weg, interpunctie) in dezelfde taal
#   en     = inspreken in je eigen taal, Engelse tekst eruit (taalcode = vertalen)
# DICTATE_POSTPROCESS=off

# Welk Groq-model de nabewerking gebruikt (opschonen/vertalen).
# GROQ_CLEANUP_MODEL=llama-3.3-70b-versatile

# ── Abonnement (managed) ────────────────────────────────────────────────
# Licentiesleutel van een Pro/Team/Lifetime-abonnement (begint met LZT.).
# Met een geldige sleutel kun je de engine "managed" gebruiken: dan loopt de
# transcriptie via lazytype.com en heb je GÉÉN eigen Groq-key nodig.
# LAZYTYPE_LICENSE=

# Endpoint van de managed-proxy (alleen overschrijven voor testen).
# LAZYTYPE_API=https://lazytype.com/api/transcribe.php

# ── Alleen voor de OWNER (admin.py) — NOOIT meeleveren in de client! ─────
# Geheim om licentiesleutels te ondertekenen. admin.py maakt 'm aan bij de
# eerste sleutel. Zet DEZELFDE waarde op de server (api/config.php).
# LAZYTYPE_LICENSE_SECRET=
